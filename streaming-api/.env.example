# Supabase Storage — bucket `tracks` (público) com 1.mp3..6.mp3
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-public-key>

# Redis para BullMQ — Railway injeta REDIS_URL automaticamente via add-on
# Em dev local, deixe vazio para cair no fallback localhost:6379
REDIS_URL=

# CORS — lista separada por vírgula com as origens do frontend em produção
# Ex.: https://music-streaming.vercel.app,https://music-streaming-git-main-<user>.vercel.app
CORS_ORIGIN=

# Railway injeta PORT automaticamente; em dev local cai para 3001
PORT=3001
